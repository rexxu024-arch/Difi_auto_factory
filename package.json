{
  "name": "openclaw-difi-factory",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw Difi Auto Factory local operator shortcuts",
  "scripts": {
    "setup:win": "py -m venv .venv && .venv\\Scripts\\python -m pip install --upgrade pip && .venv\\Scripts\\python -m pip install -r requirements.txt",
    "doctor": "scripts\\openclaw-python.cmd modules\\factory_supervisor.py",
    "local": "scripts\\openclaw-python.cmd modules\\factory_supervisor.py --execute-local --skip-network",
    "network": "scripts\\openclaw-python.cmd modules\\network_guard.py",
    "printify:login": "powershell -NoProfile -Command \"$env:OPENCLAW_PRINTIFY_CDP_PORT='9223'; cmd /c scripts\\openclaw-python.cmd modules\\printify_login_guard.py\"",
    "printify:login:dry": "powershell -NoProfile -Command \"$env:OPENCLAW_PRINTIFY_CDP_PORT='9223'; cmd /c scripts\\openclaw-python.cmd modules\\printify_login_guard.py --dry-run\"",
    "printify:cover-repair": "scripts\\openclaw-python.cmd modules\\factory_cover_repair_runner.py --limit 1 --post-sync-wait 120",
    "printify:self-heal:dry": "scripts\\openclaw-python.cmd modules\\self_healing_daemon.py --limit 20 --sleep-seconds 0 --json",
    "printify:self-heal": "scripts\\openclaw-python.cmd modules\\self_healing_daemon.py --limit 20 --execute --sleep-seconds 2",
    "ebay:replacement-draft": "scripts\\openclaw-python.cmd modules\\ebay_replacement_draft_builder.py --limit 1",
    "ebay:retire-queue": "scripts\\openclaw-python.cmd modules\\ebay_retire_queue_from_audit.py",
    "printify:design-audit": "scripts\\openclaw-python.cmd modules\\printify_design_audit.py --limit 2 --sleep-seconds 1",
    "etsy:api-status": "scripts\\openclaw-python.cmd modules\\etsy_app_status_probe.py",
    "etsy:fee:reconcile:dry": "scripts\\openclaw-python.cmd modules\\etsy_fee_reconciler.py",
    "etsy:fee:reconcile": "scripts\\openclaw-python.cmd modules\\etsy_fee_reconciler.py --execute",
    "system:resources": "scripts\\openclaw-python.cmd modules\\system_resource_allocator.py --json",
    "system:resources:watch": "scripts\\openclaw-python.cmd modules\\system_resource_allocator.py --watch --interval-seconds 300",
    "hardware:heartbeat": "scripts\\openclaw-python.cmd modules\\hardware_heartbeat_monitor.py --once --json",
    "hardware:cooldown": "scripts\\openclaw-python.cmd modules\\hardware_cooldown_guard.py --json",
    "quality:floor": "scripts\\openclaw-python.cmd modules\\quality_floor_guard.py --paths Database --limit 80",
    "grunt:seed": "scripts\\openclaw-python.cmd modules\\task_queue_modular.py --seed-default",
    "grunt:queue": "scripts\\openclaw-python.cmd modules\\task_queue_modular.py --list",
    "grunt:once": "scripts\\openclaw-python.cmd modules\\grunt_engine.py --once",
    "grunt:dry": "scripts\\openclaw-python.cmd modules\\grunt_engine.py --once --dry-run",
    "grunt:cruise": "scripts\\openclaw-python.cmd modules\\grunt_engine.py --loop --interval-seconds 300",
    "ebay:quiet-jade:prepare": "scripts\\openclaw-python.cmd modules\\ebay_quiet_jade_pivot.py --prepare --apply-local --limit 42",
    "ebay:quiet-jade:sync": "scripts\\openclaw-python.cmd modules\\ebay_quiet_jade_pivot.py --sync-printify --limit 42",
    "ebay:seo-strike:prepare": "scripts\\openclaw-python.cmd modules\\ebay_seo_strike_batch.py --prepare --apply-local --limit 10",
    "ebay:seo-strike:sync": "scripts\\openclaw-python.cmd modules\\ebay_seo_strike_batch.py --sync-printify --limit 10",
    "market:multi-track": "scripts\\openclaw-python.cmd modules\\multi_track_experiment_planner.py --json",
    "market:track-a:prepare": "scripts\\openclaw-python.cmd modules\\multi_track_copy_executor.py --track A_LOW_COMPETITION_NICHE --prepare --apply-local --limit 10",
    "market:track-a:sync:dry": "scripts\\openclaw-python.cmd modules\\multi_track_copy_executor.py --sync-printify --dry-run --limit 10",
    "market:track-a:sync": "scripts\\openclaw-python.cmd modules\\multi_track_copy_executor.py --sync-printify --limit 5 --sleep-min 18 --sleep-max 41",
    "market:track-a:monitor": "scripts\\openclaw-python.cmd modules\\multi_track_copy_monitor.py",
    "browser:edge": "scripts\\openclaw-python.cmd modules\\automation_browser.py --browser edge --port 9223",
    "browser:edge:check": "scripts\\openclaw-python.cmd modules\\automation_browser.py --check --port 9223",
    "report": "scripts\\openclaw-python.cmd modules\\factory_morning_report.py",
    "backlog": "scripts\\openclaw-python.cmd modules\\factory_backlog.py"
  }
}
