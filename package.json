{
  "name": "openclaw-difi-factory",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw Difi Auto Factory local operator shortcuts",
  "scripts": {
    "setup:win": "py -m venv .venv && .venv\\Scripts\\python -m pip install --upgrade pip && .venv\\Scripts\\python -m pip install -r requirements.txt",
    "doctor": "py modules\\factory_supervisor.py",
    "local": "py modules\\factory_supervisor.py --execute-local --skip-network",
    "network": "py modules\\network_guard.py",
    "printify:login": "powershell -NoProfile -Command \"$env:OPENCLAW_PRINTIFY_CDP_PORT='9223'; py modules\\printify_login_guard.py\"",
    "printify:login:dry": "powershell -NoProfile -Command \"$env:OPENCLAW_PRINTIFY_CDP_PORT='9223'; py modules\\printify_login_guard.py --dry-run\"",
    "printify:cover-repair": "py modules\\factory_cover_repair_runner.py --limit 1 --post-sync-wait 120",
    "printify:self-heal:dry": "py modules\\self_healing_daemon.py --limit 20 --sleep-seconds 0 --json",
    "printify:self-heal": "py modules\\self_healing_daemon.py --limit 20 --execute --sleep-seconds 2",
    "ebay:replacement-draft": "py modules\\ebay_replacement_draft_builder.py --limit 1",
    "ebay:retire-queue": "py modules\\ebay_retire_queue_from_audit.py",
    "printify:design-audit": "py modules\\printify_design_audit.py --limit 2 --sleep-seconds 1",
    "etsy:api-status": "py modules\\etsy_app_status_probe.py",
    "browser:edge": "py modules\\automation_browser.py --browser edge --port 9223",
    "browser:edge:check": "py modules\\automation_browser.py --check --port 9223",
    "report": "py modules\\factory_morning_report.py",
    "backlog": "py modules\\factory_backlog.py"
  }
}
